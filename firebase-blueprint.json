{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the system, can be an admin, superadmin, or employee.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "employee", "superadmin"] },
        "employeeId": { "type": "string" },
        "companyId": { "type": "string" },
        "currentCompanyId": { "type": "string" },
        "avatar": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "role"]
    },
    "Employee": {
      "title": "Employee",
      "description": "An employee record within a company.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "employeeId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "mobile": { "type": "string" },
        "dob": { "type": "string" },
        "designation": { "type": "string" },
        "joiningDate": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Terminated", "Resigned"] },
        "bloodGroup": { "type": "string" },
        "nationalId": { "type": "string" },
        "department": { "type": "string" },
        "employeeType": { "type": "string" },
        "location": { "type": "string" },
        "city": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "salary": { "type": "number" },
        "taxDeduction": { "type": "number" },
        "bankName": { "type": "string" },
        "bankAccountNo": { "type": "string" },
        "modeOfPayment": { "type": "string" }
      },
      "required": ["id", "companyId", "employeeId", "name", "status"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "A log of an action performed in the system.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "module": { "type": "string" },
        "recordId": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "userId", "userName", "action", "module", "description", "timestamp"]
    },
    "TimeTracking": {
      "title": "Time Tracking",
      "description": "A record of an employee's time tracking for a specific day.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string" },
        "lastActive": { "type": "number" }
      },
      "required": ["companyId", "employeeId", "date", "status"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "An attendance record for an employee.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string" },
        "loginTime": { "type": "string" },
        "currentState": { "type": "string" }
      },
      "required": ["companyId", "employeeId", "date"]
    },
    "GenericEntity": {
      "title": "Generic Entity",
      "description": "A generic entity used for various lists like departments, designations, etc.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "companyId", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Employee records."
    },
    "/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "Audit logs for system actions."
    },
    "/timeTracking/{trackingId}": {
      "schema": "TimeTracking",
      "description": "Time tracking records."
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records."
    },
    "/awards/{awardId}": { "schema": "GenericEntity", "description": "Awards." },
    "/departments/{deptId}": { "schema": "GenericEntity", "description": "Departments." },
    "/designations/{desigId}": { "schema": "GenericEntity", "description": "Designations." },
    "/subDepartments/{subDeptId}": { "schema": "GenericEntity", "description": "Sub-departments." },
    "/notices/{noticeId}": { "schema": "GenericEntity", "description": "Notices." },
    "/projects/{projectId}": { "schema": "GenericEntity", "description": "Projects." },
    "/assets/{assetId}": { "schema": "GenericEntity", "description": "Assets." },
    "/tasks/{taskId}": { "schema": "GenericEntity", "description": "Tasks." },
    "/sales/{saleId}": { "schema": "GenericEntity", "description": "Sales." },
    "/milestones/{milestoneId}": { "schema": "GenericEntity", "description": "Milestones." },
    "/loans/{loanId}": { "schema": "GenericEntity", "description": "Loans." },
    "/payrolls/{payrollId}": { "schema": "GenericEntity", "description": "Payrolls." },
    "/payrollBatches/{batchId}": { "schema": "GenericEntity", "description": "Payroll batches." },
    "/salaryRecords/{recordId}": { "schema": "GenericEntity", "description": "Salary records." },
    "/orgChartTemplates/{templateId}": { "schema": "GenericEntity", "description": "Org chart templates." },
    "/procurementRequests/{requestId}": { "schema": "GenericEntity", "description": "Procurement requests." },
    "/procurementSettings/{settingId}": { "schema": "GenericEntity", "description": "Procurement settings." },
    "/crm_companies/{companyId}": { "schema": "GenericEntity", "description": "CRM companies." },
    "/products/{productId}": { "schema": "GenericEntity", "description": "Products." },
    "/salesOrders/{orderId}": { "schema": "GenericEntity", "description": "Sales orders." },
    "/quotations/{quotationId}": { "schema": "GenericEntity", "description": "Quotations." },
    "/bids/{bidId}": { "schema": "GenericEntity", "description": "Bids." },
    "/callLogs/{logId}": { "schema": "GenericEntity", "description": "Call logs." },
    "/tickets/{ticketId}": { "schema": "GenericEntity", "description": "Tickets." },
    "/idle_alert_settings/{settingId}": { "schema": "GenericEntity", "description": "Idle alert settings." },
    "/idle_alert_logs/{logId}": { "schema": "GenericEntity", "description": "Idle alert logs." },
    "/attendance_alert_settings/{settingId}": { "schema": "GenericEntity", "description": "Attendance alert settings." },
    "/attendance_alert_logs/{logId}": { "schema": "GenericEntity", "description": "Attendance alert logs." },
    "/employee_welcome_settings/{settingId}": { "schema": "GenericEntity", "description": "Employee welcome settings." }
  }
}
