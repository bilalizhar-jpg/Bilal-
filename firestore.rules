rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // PUBLIC READ COLLECTIONS
    // These collections must be publicly readable because the application uses 
    // a custom authentication system (client-side check) for Company Admins and Employees,
    // meaning they are NOT authenticated in Firebase Auth when accessing this data.
    
    match /companies/{companyId} {
      allow read: if true;
      allow write: if true;
    }

    match /employees/{employeeId} {
      allow read: if true;
      allow write: if true;
    }

    match /invoices/{invoiceId} {
      allow read: if true;
      allow write: if true;
    }

    // Collections used by Company Admin/Employee (Custom Auth)
    match /letters/{document=**} { allow read: if true; allow write: if true; }
    match /letterTemplates/{document=**} { allow read: if true; allow write: if true; }
    match /leaves/{document=**} { allow read: if true; allow write: if true; }
    match /attendance/{document=**} { allow read: if true; allow write: if true; }
    match /policies/{document=**} { allow read: if true; allow write: if true; }
    match /timeTracking/{document=**} { allow read: if true; allow write: if true; }
    match /company_invoices/{document=**} { allow read: if true; allow write: if true; }
    match /leave_types/{document=**} { allow read: if true; allow write: if true; }
    match /holidays/{document=**} { allow read: if true; allow write: if true; }
    match /weekly_holidays/{document=**} { allow read: if true; allow write: if true; }
    match /orgChartTemplates/{document=**} { allow read: if true; allow write: if true; }
    
    // Company Data Collections
    match /awards/{document=**} { allow read: if true; allow write: if true; }
    match /departments/{document=**} { allow read: if true; allow write: if true; }
    match /designations/{document=**} { allow read: if true; allow write: if true; }
    match /subDepartments/{document=**} { allow read: if true; allow write: if true; }
    match /notices/{document=**} { allow read: if true; allow write: if true; }
    match /projects/{document=**} { allow read: if true; allow write: if true; }
    match /assets/{document=**} { allow read: if true; allow write: if true; }
    match /tasks/{document=**} { allow read: if true; allow write: if true; }
    match /hr_jobs/{document=**} { allow read: if true; allow write: if true; }
    match /hr_applications/{document=**} { allow read: if true; allow write: if true; }
    match /candidates/{document=**} { allow read: if true; allow write: if true; }
    match /milestones/{document=**} { allow read: if true; allow write: if true; }
    match /sales/{document=**} { allow read: if true; allow write: if true; }
    match /payrollBatches/{document=**} { allow read: if true; allow write: if true; }
    match /salaryRecords/{document=**} { allow read: if true; allow write: if true; }
    match /payrolls/{document=**} { allow read: if true; allow write: if true; }
    match /loans/{document=**} { allow read: if true; allow write: if true; }
    match /chats/{document=**} { allow read: if true; allow write: if true; }
    match /invitations/{document=**} { allow read: if true; allow write: if true; }
    match /marketing_campaigns/{document=**} { allow read: if true; allow write: if true; }
    match /marketing_logs/{document=**} { allow read: if true; allow write: if true; }
    match /marketing_lists/{document=**} { allow read: if true; allow write: if true; }
    match /settings/{document=**} { allow read: if true; allow write: if true; }
    match /trainingPrograms/{document=**} { allow read: if true; allow write: if true; }
    match /procurementRequests/{document=**} { allow read: if true; allow write: if true; }
    match /procurementSettings/{document=**} { allow read: if true; allow write: if true; }
    match /appraisals/{document=**} { allow read: if true; allow write: if true; }

    // Accounts Collections
    match /bankAccounts/{document=**} { allow read: if true; allow write: if true; }
    match /bankTransfers/{document=**} { allow read: if true; allow write: if true; }
    match /accountPayments/{document=**} { allow read: if true; allow write: if true; }
    match /vouchers/{document=**} { allow read: if true; allow write: if true; }
    match /ledgerGroups/{document=**} { allow read: if true; allow write: if true; }
    match /ledgers/{document=**} { allow read: if true; allow write: if true; }
    match /accountBills/{document=**} { allow read: if true; allow write: if true; }
    match /accountPeople/{document=**} { allow read: if true; allow write: if true; }

    // Users (Super Admin) - Keep restricted
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
