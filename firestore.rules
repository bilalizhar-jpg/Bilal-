rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: id, name, email, role, companyId, currentCompanyId, avatar, lastLogin
    //
    // Collection: employees
    // Fields: id, companyId, employeeId, name, email, mobile, dob, designation, joiningDate, status, ...
    //
    // Collection: auditLogs
    // Fields: companyId, userId, userName, action, module, recordId, description, timestamp
    //
    // Collection: timeTracking
    // Fields: companyId, employeeId, date, status, lastActive
    //
    // Collection: attendance
    // Fields: companyId, employeeId, date, loginTime, currentState
    //
    // Generic Collections (awards, departments, designations, etc.):
    // Fields: id, companyId, name, status, ...
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin' ||
          (request.auth.token.email == "bilal.izhar@algorepublic.com" && request.auth.token.email_verified == true));
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin' ||
          (request.auth.token.email == "bilal.izhar@algorepublic.com" && request.auth.token.email_verified == true));
    }

    function belongsToCompany(companyId) {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.currentCompanyId == companyId ||
         isSuperAdmin());
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'role']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role in ['admin', 'employee', 'superadmin'];
    }

    function isValidEmployee(data) {
      return data.keys().hasAll(['id', 'companyId', 'employeeId', 'name', 'status']) &&
             data.id is string &&
             data.companyId is string &&
             data.employeeId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.status in ['Active', 'Inactive', 'Terminated', 'Resigned'];
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['companyId', 'userId', 'userName', 'action', 'module', 'description', 'timestamp']) &&
             data.companyId is string &&
             data.userId is string &&
             data.userName is string &&
             data.action is string &&
             data.module is string &&
             data.description is string &&
             data.timestamp is string;
    }

    function isValidGeneric(data) {
      return data.keys().hasAll(['id', 'companyId', 'name']) &&
             data.id is string &&
             data.companyId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) || isSuperAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) || isSuperAdmin()) &&
                    (request.resource.data.role == resource.data.role || isSuperAdmin());
    }

    match /employees/{employeeId} {
      allow read: if belongsToCompany(resource.data.companyId);
      allow create: if isAuthenticated() && isValidEmployee(request.resource.data) && 
                    belongsToCompany(request.resource.data.companyId) && isAdmin();
      allow update: if isAuthenticated() && isValidEmployee(request.resource.data) && 
                    belongsToCompany(resource.data.companyId) && isAdmin();
      allow delete: if isAuthenticated() && belongsToCompany(resource.data.companyId) && isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if belongsToCompany(resource.data.companyId) && isAdmin();
      allow create: if isAuthenticated() && isValidAuditLog(request.resource.data) && 
                    belongsToCompany(request.resource.data.companyId);
    }

    match /timeTracking/{trackingId} {
      allow read: if belongsToCompany(resource.data.companyId);
      allow write: if isAuthenticated() && belongsToCompany(request.resource.data.companyId);
    }

    match /attendance/{attendanceId} {
      allow read: if belongsToCompany(resource.data.companyId);
      allow write: if isAuthenticated() && belongsToCompany(request.resource.data.companyId);
    }

    match /test/connection {
      allow get: if isAuthenticated();
    }

    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isSuperAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if belongsToCompany(resource.data.companyId);
      allow create, update, delete: if belongsToCompany(request.resource.data.companyId) && isAdmin();
    }

    match /invoiceItems/{itemId} {
      allow read: if belongsToCompany(resource.data.companyId);
      allow create, update, delete: if belongsToCompany(request.resource.data.companyId) && isAdmin();
    }

    match /weekly_holidays/{holidayId} {
      allow read: if belongsToCompany(resource.data.companyId);
      allow create, update, delete: if belongsToCompany(request.resource.data.companyId) && isAdmin();
    }

    // Generic collections
    match /{collectionName}/{entityId} {
      allow read: if collectionName in [
        'awards', 'departments', 'designations', 'subDepartments', 'notices', 
        'projects', 'assets', 'tasks', 'sales', 'milestones', 'loans', 
        'payrolls', 'payrollBatches', 'salaryRecords', 'orgChartTemplates', 
        'procurementRequests', 'procurementSettings', 'crm_companies', 
        'products', 'salesOrders', 'quotations', 'bids', 'callLogs', 'tickets',
        'idle_alert_settings', 'idle_alert_logs', 'attendance_alert_settings',
        'attendance_alert_logs', 'employee_welcome_settings', 'vendors', 'expenses',
        'bills', 'billItems', 'bankAccounts', 'bankTransactions', 'fiscalYears',
        'journalEntries', 'journalLines', 'accounts', 'customers', 'marketingLists',
        'campaigns', 'campaignLogs', 'trainingPrograms', 'policies', 'letters',
        'letterTemplates', 'invitations', 'chats'
      ] && (
        (collectionName == 'crm_companies' && isSuperAdmin()) ||
        belongsToCompany(resource.data.companyId)
      );
      
      allow create: if collectionName in [
        'awards', 'departments', 'designations', 'subDepartments', 'notices', 
        'projects', 'assets', 'tasks', 'sales', 'milestones', 'loans', 
        'payrolls', 'payrollBatches', 'salaryRecords', 'orgChartTemplates', 
        'procurementRequests', 'procurementSettings', 'crm_companies', 
        'products', 'salesOrders', 'quotations', 'bids', 'callLogs', 'tickets',
        'idle_alert_settings', 'idle_alert_logs', 'attendance_alert_settings',
        'attendance_alert_logs', 'employee_welcome_settings', 'vendors', 'expenses',
        'bills', 'billItems', 'bankAccounts', 'bankTransactions', 'fiscalYears',
        'journalEntries', 'journalLines', 'accounts', 'customers', 'marketingLists',
        'campaigns', 'campaignLogs', 'trainingPrograms', 'policies', 'letters',
        'letterTemplates', 'invitations', 'chats'
      ] && isValidGeneric(request.resource.data) && (
        (collectionName == 'crm_companies' && isSuperAdmin()) ||
        (belongsToCompany(request.resource.data.companyId) && isAdmin())
      );

      allow update: if collectionName in [
        'awards', 'departments', 'designations', 'subDepartments', 'notices', 
        'projects', 'assets', 'tasks', 'sales', 'milestones', 'loans', 
        'payrolls', 'payrollBatches', 'salaryRecords', 'orgChartTemplates', 
        'procurementRequests', 'procurementSettings', 'crm_companies', 
        'products', 'salesOrders', 'quotations', 'bids', 'callLogs', 'tickets',
        'idle_alert_settings', 'idle_alert_logs', 'attendance_alert_settings',
        'attendance_alert_logs', 'employee_welcome_settings', 'vendors', 'expenses',
        'bills', 'billItems', 'bankAccounts', 'bankTransactions', 'fiscalYears',
        'journalEntries', 'journalLines', 'accounts', 'customers', 'marketingLists',
        'campaigns', 'campaignLogs', 'trainingPrograms', 'policies', 'letters',
        'letterTemplates', 'invitations', 'chats'
      ] && isValidGeneric(request.resource.data) && (
        (collectionName == 'crm_companies' && isSuperAdmin()) ||
        (belongsToCompany(resource.data.companyId) && isAdmin())
      );

      allow delete: if collectionName in [
        'awards', 'departments', 'designations', 'subDepartments', 'notices', 
        'projects', 'assets', 'tasks', 'sales', 'milestones', 'loans', 
        'payrolls', 'payrollBatches', 'salaryRecords', 'orgChartTemplates', 
        'procurementRequests', 'procurementSettings', 'crm_companies', 
        'products', 'salesOrders', 'quotations', 'bids', 'callLogs', 'tickets',
        'idle_alert_settings', 'idle_alert_logs', 'attendance_alert_settings',
        'attendance_alert_logs', 'employee_welcome_settings', 'vendors', 'expenses',
        'bills', 'billItems', 'bankAccounts', 'bankTransactions', 'fiscalYears',
        'journalEntries', 'journalLines', 'accounts', 'customers', 'marketingLists',
        'campaigns', 'campaignLogs', 'trainingPrograms', 'policies', 'letters',
        'letterTemplates', 'invitations', 'chats'
      ] && (
        (collectionName == 'crm_companies' && isSuperAdmin()) ||
        (belongsToCompany(resource.data.companyId) && isAdmin())
      );
    }
  }
}
